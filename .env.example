# WatchDogAI configuration — copy to .env and adjust.
# Every value can also be set as a plain environment variable.

# --- Cameras -----------------------------------------------------------
# JSON array; one entry per camera. source = webcam index, video file
# path, or RTSP/HTTP stream URL. width/height/fps are optional quality
# hints applied to the capture device.
CAMERAS=[{"id": "cam-north", "name": "North Gate", "source": "rtsp://10.0.0.11:554/stream1", "width": 1280, "height": 720, "fps": 15}, {"id": "cam-south", "name": "South Gate", "source": "rtsp://10.0.0.12:554/stream1", "width": 1280, "height": 720, "fps": 15}]
# Single-camera fallback used only when CAMERAS is not set:
#CAMERA_SOURCE=0

# --- Violence detection ------------------------------------------------
CONFIDENCE_THRESHOLD=0.85
CONSECUTIVE_HITS=3
COOLDOWN_SECONDS=5

# --- People/vehicle detection & tracking (YOLO + ByteTrack) ------------
OBJECT_DETECTION=true
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4

# --- Abnormal behavior analytics ---------------------------------------
BEHAVIOR_DETECTION=true
LOITER_SECONDS=60
RUN_SPEED_THRESHOLD=0.35
ANOMALY_MIN_SAMPLES=200
BEHAVIOR_EVENT_COOLDOWN=30

# --- Video clips --------------------------------------------------------
PRE_EVENT_SECONDS=3
POST_EVENT_SECONDS=2
CLIP_DIR=data/clips

# --- Storage (MongoDB preferred, SQLite fallback) -----------------------
# auto = use MongoDB when reachable, otherwise fall back to SQLite
DB_BACKEND=auto
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=watchdog
DB_PATH=data/watchdog.db

# --- Municipal control center (HTTP push, alert JSON + MP4 clip) --------
#CONTROL_CENTER_URL=https://control-center.holon.example/api/alerts
#CONTROL_CENTER_API_KEY=change-me

# --- LoRa smart-campus gateway (MQTT) -----------------------------------
#MQTT_HOST=gateway.campus.hit.ac.il
MQTT_PORT=1883
#MQTT_USERNAME=
#MQTT_PASSWORD=
MQTT_BASE_TOPIC=watchdog
TELEMETRY_INTERVAL=30

# --- Dashboard -----------------------------------------------------------
DASHBOARD_PORT=8000
# Require this token for all dashboard/API access (recommended).
# Browsers: open http://host:8000/?token=<value> once; API clients:
# send the X-API-Token header.
#API_TOKEN=change-me

# --- Misc ---------------------------------------------------------------
CAMERA_HEALTH_MAX_AGE=5
LOG_DIR=logs
LOG_LEVEL=INFO
