# WatchDogAI configuration — copy to .env and adjust.
# Every value can also be set as a plain environment variable.

# --- Cameras -----------------------------------------------------------
# JSON array; one entry per camera. source = webcam index, video file
# path, a folder of video files, or an RTSP/HTTP stream URL. width/height/fps
# are optional quality hints applied to the capture device.
#
# A source that is a FOLDER expands into one camera per video file found
# directly inside it (non-recursive), each with its own id (<id>-0, <id>-1,
# ...), dashboard card, and alert attribution — use this to process a batch
# of recorded footage alongside live camera streams in the same deployment:
#   {"id": "archive", "source": "C:/footage/2026-07-05"}
#   -> archive-0, archive-1, ... (one per video file in that folder)
CAMERAS=[{"id": "cam-north", "name": "North Gate", "source": "rtsp://10.0.0.11:554/stream1", "width": 1280, "height": 720, "fps": 15}, {"id": "cam-south", "name": "South Gate", "source": "rtsp://10.0.0.12:554/stream1", "width": 1280, "height": 720, "fps": 15}]
# Single-camera fallback used only when CAMERAS is not set. A source can be
# a webcam index (0), a video file path, a folder of video files (see
# above), or an rtsp://... / http://... stream URL. On Windows, use forward
# slashes and no surrounding quotes to avoid backslash-escape parsing issues:
#CAMERA_SOURCE=0
#CAMERA_SOURCE=C:/videos/sample.mp4

# --- Source-mode switching (dashboard toggle) ---------------------------
# When RECORDINGS_DIR points at a folder of video files, the Live View
# gets a "Live cameras / Recordings" toggle that swaps the running
# pipelines at runtime — no restart needed. CAMERAS / CAMERA_SOURCE above
# define what "live" means; RECORDINGS_DIR defines what "recordings"
# plays (one camera per file, re-scanned on every switch).
#RECORDINGS_DIR=C:/footage/2026-07-05
# Which mode to start in: live (default) or recordings
SOURCE_MODE=live
# --- Violence detection ------------------------------------------------
CONFIDENCE_THRESHOLD=0.85
CONSECUTIVE_HITS=3
COOLDOWN_SECONDS=5

# --- People/vehicle detection & tracking (YOLO + ByteTrack) ------------
OBJECT_DETECTION=true
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.4

# --- Abnormal behavior analytics ---------------------------------------
BEHAVIOR_DETECTION=true
LOITER_SECONDS=60
RUN_SPEED_THRESHOLD=0.35
ANOMALY_MIN_SAMPLES=200
BEHAVIOR_EVENT_COOLDOWN=30
# Behavior events (loitering/running/anomalous movement) are always shown
# live on the dashboard. By default they do NOT save a clip or create an
# alert — only confirmed violence does. Set to true to record clips for
# behavior events too.
RECORD_BEHAVIOR_CLIPS=false

# --- Video clips --------------------------------------------------------
PRE_EVENT_SECONDS=3
POST_EVENT_SECONDS=2
# Long events are chunked into clips of at most this length
MAX_CLIP_SECONDS=30
CLIP_DIR=data/clips

# --- Storage (MongoDB preferred, SQLite fallback) -----------------------
# auto = use MongoDB when reachable, otherwise fall back to SQLite
DB_BACKEND=auto
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=watchdog
DB_PATH=data/watchdog.db

# --- Municipal control center (HTTP push, alert JSON + MP4 clip) --------
#CONTROL_CENTER_URL=https://control-center.holon.example/api/alerts
#CONTROL_CENTER_API_KEY=change-me

# --- LoRa smart-campus gateway (MQTT) -----------------------------------
#MQTT_HOST=gateway.campus.hit.ac.il
MQTT_PORT=1883
#MQTT_USERNAME=
#MQTT_PASSWORD=
MQTT_BASE_TOPIC=watchdog
TELEMETRY_INTERVAL=30

# --- Dashboard -----------------------------------------------------------
DASHBOARD_PORT=8000
# Require this token for all dashboard/API access (recommended).
# Browsers: open http://host:8000/?token=<value> once; API clients:
# send the X-API-Token header.
#API_TOKEN=change-me

# --- Misc ---------------------------------------------------------------
CAMERA_HEALTH_MAX_AGE=5
LOG_DIR=logs
LOG_LEVEL=INFO
